# Postgres connection string (Prisma Postgres / Neon / Vercel Postgres / local). Required by Payload.
# Prisma Postgres — use the plain TCP string from the Console, NOT the prisma+postgres:// Accelerate URL.
#   Local + migrations (direct): postgres://USER:PASSWORD@db.prisma.io:5432/?sslmode=require
#   Vercel runtime (pooled):     postgres://USER:PASSWORD@pooled.db.prisma.io:5432/?sslmode=require
DATABASE_URL=postgres://user:password@127.0.0.1:5432/map_clippy
# Random secret used to sign Payload auth tokens.
PAYLOAD_SECRET=YOUR_SECRET_HERE
# PartyKit host for live duels (set once the party server is deployed).
NEXT_PUBLIC_PARTYKIT_HOST=127.0.0.1:1999
# Shared secret for the daily-generation cron route. Vercel Cron sends it as
# `Authorization: Bearer <CRON_SECRET>`. If unset, the route is unprotected.
CRON_SECRET=YOUR_CRON_SECRET_HERE
