# Postgres connection string (Neon / Vercel Postgres / local). Required by Payload.
DATABASE_URL=postgres://user:password@127.0.0.1:5432/map_clippy
# Random secret used to sign Payload auth tokens.
PAYLOAD_SECRET=YOUR_SECRET_HERE
# PartyKit host for live duels (set once the party server is deployed).
NEXT_PUBLIC_PARTYKIT_HOST=127.0.0.1:1999
# Shared secret for the daily-generation cron route. Vercel Cron sends it as
# `Authorization: Bearer <CRON_SECRET>`. If unset, the route is unprotected.
CRON_SECRET=YOUR_CRON_SECRET_HERE
